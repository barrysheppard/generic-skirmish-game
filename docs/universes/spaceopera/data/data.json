  "traits": [
    { "id": "accurate", "name": "Accurate", "type": "weapon-trait", "ability_cost": "[double]", "effect": "Increase the Weapon Skill (BS/WS) of attacks with this weapon this turn by 1." },
    { "id": "beskar", "name": "Beskar", "type": "weapon-trait", "ability_cost": "[passive]", "effect": "For the purposes of the Lightsaber trait, this weapon is considered a Lightsaber." },
    { "id": "blast", "name": "Blast", "type": "weapon-trait", "ability_cost": "[double]", "effect": "For the next attack with this weapon, all fighters within the specified radius (default 2\") of the target take 2 damage if the attack rolls at least one hit or crit." },
    { "id": "convertible", "name": "Convertible", "type": "weapon-trait", "ability_cost": "[double]", "effect": "Start the game in one configuration. Use this double to switch the weapon to a different mode listed in its profile." },
