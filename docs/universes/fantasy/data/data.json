  "weapon_traits": [
    { "name": "Block", "ability_cost": "[double]", "effect": "Reaction: After a ranged attack has been rolled against this fighter but before damage is calculated, change a crit to a hit.", "cost": "-", "type": "weapon-trait" },
    { "name": "Brutal", "ability_cost": "[double]", "effect": "A fighter can only use this ability if an enemy fighter has been taken down by an attack action or ability made by this fighter during this activation. This fighter makes a bonus attack action.", "cost": "-", "type": "weapon-trait" },
    { "name": "Cleaving", "ability_cost": "[triple]", "effect": "Allocate a number of damage points equal to half the value of this ability (rounding up) to all visible enemy fighters within 1\" of this fighter.", "cost": "-", "type": "weapon-trait" },
    { "name": "Crushing", "ability_cost": "[double]", "effect": "Until the end of the Mission round, increase the Weapon Skill of attacks with this weapon by 2.", "cost": "-", "type": "weapon-trait" },
    { "name": "Overwhelming", "ability_cost": "[double]", "effect": "After an attack with this weapon does damage, push the fighter who took damage back 2 inches.", "cost": "-", "type": "weapon-trait" },
    { "name": "Parry", "ability_cost": "[double]", "effect": "Reaction: A fighter can make this reaction after they have been hit by a melee attack action but before damage is assigned. Change one hit from that attack action to a miss (this cannot modify a crit).", "cost": "-", "type": "weapon-trait" },
    { "name": "Piercing", "ability_cost": "[double]", "effect": "Until the end of the Mission round, attacks with this weapon crit one step earlier (e.g. if it would crit on a 6 it now also crits on a 5, if it couldn't crit then it would crit on a 6).", "cost": "-", "type": "weapon-trait" },
    { "name": "Precise", "ability_cost": "[double]", "effect": "Until the end of the Mission round, add 1 to the Attacks characteristic of attack actions made by this weapon.", "cost": "-", "type": "weapon-trait" },
    { "name": "Quick", "ability_cost": "[double]", "effect": "Before attacking with this weapon, this fighter can take a 2 inch move (but not disengage).", "cost": "-", "type": "weapon-trait" },
    { "name": "Riposte", "ability_cost": "[double]", "effect": "Reaction: A fighter can make this reaction after a melee attack targeting them was rolled with no hits or crits, the attacker takes one hit's worth of damage from the Riposte weapon.", "cost": "-", "type": "weapon-trait" },
    { "name": "Spiked", "ability_cost": "[double]", "effect": "Allocate a number of damage points equal to half the value of this ability to a fighter who has taken damage from this weapon this turn.", "cost": "-", "type": "weapon-trait" },
    { "name": "Sprint", "ability_cost": "[double]", "effect": "Increase the movement value of this fighter by 1 until the end of their activation.", "cost": "-", "type": "weapon-trait" },
    { "name": "Thrown", "ability_cost": "[double]", "effect": "Pick a visible enemy fighter within 6\" of this fighter and roll 2 dice. For each roll of 4-5, allocate 1 damage point to that fighter. For each roll of 6, allocate a number of damage points to that fighter equal to the value of this ability.", "cost": "-", "type": "weapon-trait" }
  ],
